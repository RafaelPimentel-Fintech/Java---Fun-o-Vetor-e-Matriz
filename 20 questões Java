import java.util.Scanner;

public class Ex2 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        double[] notas = new double[n];

        for (int i = 0; i < n; i++) {
            notas[i] = sc.nextDouble();
        }

        System.out.println("Maior nota: " + maior(notas));
        System.out.println("Menor nota: " + menor(notas));
        System.out.println("Media da turma: " + media(notas));
        System.out.println("Quantidade de aprovados: " + aprovados(notas));
    }

    public static double maior(double[] v) {
        double m = v[0];
        for (int i = 1; i < v.length; i++) {
            if (v[i] > m) m = v[i];
        }
        return m;
    }

    public static double menor(double[] v) {
        double m = v[0];
        for (int i = 1; i < v.length; i++) {
            if (v[i] < m) m = v[i];
        }
        return m;
    }

    public static double media(double[] v) {
        double soma = 0;
        for (int i = 0; i < v.length; i++) {
            soma += v[i];
        }
        return soma / v.length;
    }

    public static int aprovados(double[] v) {
        int cont = 0;
        for (int i = 0; i < v.length; i++) {
            if (v[i] >= 7) cont++;
        }
        return cont;
    }
