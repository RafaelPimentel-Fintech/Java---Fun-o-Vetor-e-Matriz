import java.util.Scanner;

public class Ex3 {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int n = sc.nextInt();
        double[] precos = new double[n];

        for (int i = 0; i < n; i++) {
            precos[i] = sc.nextDouble();
        }

        int p = sc.nextInt();

        double[] novos = reajuste(precos, p);

        System.out.println("Novos precos:");
        for (double v : novos) {
            System.out.printf("%.2f ", v);
        }

        System.out.println("\nTotal antes: " + soma(precos));
        System.out.println("Total depois: " + soma(novos));
    }

    public static double[] reajuste(double[] v, int p) {
        double[] novo = new double[v.length];
        for (int i = 0; i < v.length; i++) {
            novo[i] = v[i] * (1 + p / 100.0);
        }
        return novo;
    }

    public static double soma(double[] v) {
        double total = 0;
        for (double x : v) total += x;
        return total;
    }
}

